{
  "name": "@hitch/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Watches .hitch/ folders and syncs them to Convex.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/daemon.d.ts",
      "default": "./dist/daemon.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:runner": "tsx src/runner.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke:chat-lifecycle-store": "tsx scripts/chat-lifecycle-store-smoke.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "convex": "^1.39.1",
    "dotenv": "^17.4.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
