{
  "name": "@hitch/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hitch reconciler daemon — observes local agent chats and reconciles desired vs. machine state against the Hitch server.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/daemon.d.ts",
      "default": "./dist/daemon.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:runner": "tsx src/runner.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke:chat-lifecycle-store": "tsx scripts/chat-lifecycle-store-smoke.ts",
    "smoke:chat-lifecycle-hook-fixtures": "tsx scripts/chat-lifecycle-hook-fixtures-smoke.ts",
    "smoke:chat-lifecycle-producers": "tsx scripts/chat-lifecycle-producers-smoke.ts",
    "smoke:chat-lifecycle-reducer": "tsx scripts/chat-lifecycle-reducer-smoke.ts",
    "smoke:chat-lifecycle-coalesce": "tsx scripts/chat-lifecycle-coalesce-smoke.ts",
    "smoke:chat-title": "tsx scripts/chat-title-smoke.ts",
    "smoke:chat-lifecycle-wakeup": "tsx scripts/chat-lifecycle-wakeup-smoke.ts",
    "smoke:codex-cmux-command": "tsx scripts/codex-cmux-command-smoke.ts",
    "smoke:observer-derive": "tsx scripts/observer-derive-smoke.ts",
    "smoke:observer-tail": "tsx scripts/observer-tail-smoke.ts",
    "smoke:observer-store": "tsx scripts/observer-store-smoke.ts",
    "smoke:v2-config": "tsx scripts/v2-config-smoke.ts",
    "smoke:v2-ws-backoff": "tsx scripts/v2-ws-backoff-smoke.ts",
    "smoke:v2-chat-sync": "tsx scripts/v2-chat-sync-smoke.ts",
    "smoke:v2-chat-legacy-skip": "tsx scripts/v2-chat-legacy-skip-smoke.ts",
    "smoke:v2-reconciler": "tsx scripts/v2-reconciler-smoke.ts",
    "smoke:v2-focus": "tsx scripts/v2-focus-smoke.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hitch/shared": "*",
    "chokidar": "^5.0.0",
    "dotenv": "^17.4.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
