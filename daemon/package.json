{
  "name": "@hitch/daemon",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Watches .hitch/ folders and syncs them to Convex.",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/daemon.d.ts",
      "default": "./dist/daemon.js"
    }
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:runner": "tsx src/runner.ts",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke:chat-lifecycle-store": "tsx scripts/chat-lifecycle-store-smoke.ts",
    "smoke:chat-lifecycle-hook-fixtures": "tsx scripts/chat-lifecycle-hook-fixtures-smoke.ts",
    "smoke:chat-lifecycle-producers": "tsx scripts/chat-lifecycle-producers-smoke.ts",
    "smoke:chat-lifecycle-reducer": "tsx scripts/chat-lifecycle-reducer-smoke.ts",
    "smoke:chat-lifecycle-coalesce": "tsx scripts/chat-lifecycle-coalesce-smoke.ts",
    "smoke:chat-title": "tsx scripts/chat-title-smoke.ts",
    "smoke:task-title": "tsx scripts/task-title-smoke.ts",
    "smoke:chat-frontmatter-projection": "tsx scripts/chat-frontmatter-projection-smoke.ts",
    "smoke:chat-pending-binding": "tsx scripts/chat-pending-binding-smoke.ts",
    "smoke:automation-definition": "tsx scripts/automation-definition-smoke.ts",
    "smoke:automation-scheduler": "tsx scripts/automation-scheduler-smoke.ts",
    "smoke:automation-run-lifecycle": "tsx scripts/automation-run-lifecycle-smoke.ts",
    "smoke:automation-prune-path": "tsx scripts/automation-prune-path-smoke.ts",
    "smoke:chat-lifecycle-wakeup": "tsx scripts/chat-lifecycle-wakeup-smoke.ts",
    "smoke:codex-cmux-command": "tsx scripts/codex-cmux-command-smoke.ts",
    "smoke:cmux-close-placements": "tsx scripts/cmux-close-placements-smoke.ts",
    "smoke:observer-derive": "tsx scripts/observer-derive-smoke.ts",
    "smoke:observer-tail": "tsx scripts/observer-tail-smoke.ts",
    "smoke:observer-store": "tsx scripts/observer-store-smoke.ts",
    "smoke:skills": "tsx scripts/skills-smoke.ts",
    "smoke:task-migration": "tsx scripts/task-migration-smoke.ts",
    "smoke:v2-config": "tsx scripts/v2-config-smoke.ts",
    "smoke:v2-ws-backoff": "tsx scripts/v2-ws-backoff-smoke.ts",
    "smoke:v2-chat-sync": "tsx scripts/v2-chat-sync-smoke.ts",
    "start": "node dist/index.js"
  },
  "dependencies": {
    "@hitch/shared": "*",
    "chokidar": "^5.0.0",
    "convex": "^1.39.1",
    "dotenv": "^17.4.2",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}
