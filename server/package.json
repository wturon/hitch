{
  "name": "@hitch/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hitch V2 API server (Hono on Node).",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.11",
    "hono": "^4.12.31"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "3.2.4"
  }
}
