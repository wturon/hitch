{
  "name": "@hitch/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hitch V2 API server (Hono on Node).",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "default": "./dist/app.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1093.0",
    "@aws-sdk/s3-request-presigner": "^3.1093.0",
    "@better-auth/api-key": "^1.6.24",
    "@hono/node-server": "^2.0.11",
    "@hono/node-ws": "^1.3.1",
    "@hono/zod-validator": "^0.9.0",
    "better-auth": "^1.6.24",
    "drizzle-orm": "^0.45.2",
    "fractional-indexing": "^3.2.0",
    "hono": "^4.12.31",
    "pg": "^8.22.0",
    "uuidv7": "^1.2.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pg": "^8.20.0",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "3.2.4",
    "ws": "^8.18.0"
  }
}
