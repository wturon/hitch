# Postgres connection string — the only DB coupling (docker-compose provides
# this in the self-host story; Railway injects it in prod).
DATABASE_URL=postgres://postgres:hitch@localhost:5432/hitch

# better-auth signing secret — generate one with `npx @better-auth/cli secret`.
BETTER_AUTH_SECRET=

# Public base URL of this server (better-auth cookies/redirects). Defaults to
# http://localhost:3010 when unset.
BETTER_AUTH_URL=http://localhost:3010

# HTTP port (defaults to 3010).
PORT=3010

# Run drizzle migrations before serving (1 = on). Default ON in the container
# image; local dev usually runs `npm run db:migrate` explicitly instead.
MIGRATE_ON_BOOT=

# --- Blob storage (S3-compatible) -------------------------------------------
# S3-agnostic: Railway Buckets in prod, Garage in docker-compose, R2 as
# fallback — all just env vars. The defaults below match the compose Garage
# service (dev-only credentials, baked into docker-compose.yml + the garage
# init script). Prod MUST override every S3_* value.

# Endpoint the server talks to for HEAD/DELETE.
S3_ENDPOINT=http://localhost:3900
# Endpoint baked into presigned URLs (what CLIENTS reach). Defaults to
# S3_ENDPOINT; only differs when the server's route to storage differs from
# the client's (e.g. inside docker-compose: server sees http://storage:3900,
# clients see http://localhost:3900).
S3_PUBLIC_ENDPOINT=
S3_REGION=garage
S3_BUCKET=hitch
S3_ACCESS_KEY_ID=GKa1b2c3d4e5f60718293a4b5c
S3_SECRET_ACCESS_KEY=7d4f9a2b1c8e5f30d6a4b2c19e7f5d3a8b6c4e2f0a9d7b5c3e1f8a6d4b2c0e9f
# Path-style addressing — required for Garage/MinIO-style endpoints (default true).
S3_FORCE_PATH_STYLE=true
# Upload size cap in bytes, enforced at finalize-time (default 100MB).
S3_MAX_UPLOAD_BYTES=104857600
