# The daemon connects to your Convex deployment.
#
# Easiest: just run `npx convex dev` once. It writes CONVEX_DEPLOYMENT to
# .env.local and the daemon derives the URL automatically — no need to set
# anything here.
#
# Or set the URL explicitly (overrides the derived one). It looks like:
#   CONVEX_URL=https://your-deployment-name.convex.cloud
CONVEX_URL=

# Hitch Desktop's renderer needs public Convex/project config. For local dev,
# `npx convex dev` writes CONVEX_DEPLOYMENT and the renderer can derive the URL;
# these explicit values are still supported when you want to override it.
NEXT_PUBLIC_CONVEX_URL=
NEXT_PUBLIC_HITCH_PROJECT=will-default

# Local device credential. For now, generate one from an authenticated Hitch
# session and keep it out of git. Hitch Desktop will eventually mint and store
# this automatically after sign-in.
HITCH_DEVICE_TOKEN=
