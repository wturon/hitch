# The desktop app and daemon talk to the Hitch server (Hono). Point them at your
# deployment — Railway prod, or a local `npm run dev:v2-stack` instance.
#
#   HITCH_SERVER_URL=https://server-production-xxxx.up.railway.app
HITCH_SERVER_URL=

# The daemon authenticates with an api key minted by the desktop app after
# sign-in (persisted to secrets.json). Set it explicitly only for headless/CI
# daemon runs.
HITCH_API_KEY=
