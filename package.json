{
  "name": "hitch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Hitch — AI-native task management with an agent delegation layer (Hono server + Electron desktop + reconciler daemon).",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11"
  },
  "workspaces": [
    "cli",
    "daemon",
    "desktop",
    "server",
    "shared"
  ],
  "overrides": {
    "@hono/node-server@^1.19.11": "^2.0.11"
  },
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:all": "concurrently -n server,desktop -c blue,green \"npm:dev:v2-stack\" \"npm:dev:desktop\"",
    "dev:daemon": "tsx daemon/src/index.ts",
    "dev:v2-stack": "node scripts/dev-v2-stack.mjs",
    "db:sync-from-prod": "node scripts/sync-local-from-prod.mjs",
    "dev:desktop": "npm -w desktop run dev",
    "dev:renderer": "npm -w desktop run dev:renderer",
    "dev:electron": "npm -w desktop run dev:electron",
    "typecheck": "npm -w @hitch/server run typecheck && npm -w @hitch/daemon run typecheck && npm -w desktop run typecheck",
    "check": "npm run typecheck && npm -w desktop run build && npm -w desktop run test",
    "package:desktop": "npm -w desktop run package",
    "release:desktop": "npm -w desktop run release",
    "icons": "node scripts/generate-icons.mjs"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@resvg/resvg-js": "^2.6.2",
    "concurrently": "^10.0.1",
    "png-to-ico": "^3.0.1"
  }
}
