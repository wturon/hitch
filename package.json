{
  "name": "hitch",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A local file sync engine that keeps git-ignored .hitch/ folders in sync with Convex.",
  "packageManager": "npm@11.11.0",
  "engines": {
    "node": ">=24.15.0",
    "npm": ">=11"
  },
  "workspaces": [
    "daemon",
    "desktop"
  ],
  "scripts": {
    "dev": "npm run dev:desktop",
    "dev:all": "concurrently -n convex,desktop -c blue,green \"npm:dev:convex\" \"npm:dev:desktop\"",
    "dev:convex": "convex dev",
    "dev:daemon": "tsx daemon/src/index.ts",
    "dev:desktop": "npm -w desktop run dev",
    "dev:renderer": "npm -w desktop run dev:renderer",
    "dev:electron": "npm -w desktop run dev:electron",
    "typecheck": "npm run typecheck:convex && npm -w @hitch/daemon run typecheck && npm -w desktop run typecheck",
    "typecheck:convex": "tsc -p convex/tsconfig.json --noEmit",
    "check": "npm run typecheck && npm -w desktop run build && npm -w desktop run test",
    "package:desktop": "npm -w desktop run package",
    "release:desktop": "npm -w desktop run release",
    "setup": "convex dev --once",
    "icons": "node scripts/generate-icons.mjs"
  },
  "dependencies": {
    "@auth/core": "^0.37.4",
    "@convex-dev/auth": "^0.0.92",
    "convex": "^1.39.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@resvg/resvg-js": "^2.6.2",
    "concurrently": "^10.0.1",
    "png-to-ico": "^3.0.1"
  }
}
