{
  "name": "@hitch/desktop",
  "version": "0.1.13",
  "private": true,
  "type": "module",
  "description": "Hitch Desktop — live Kanban board over git-ignored .hitch/ folders, supervising the local sync daemon.",
  "author": "Jakib",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "concurrently -k --success first -n renderer,electron -c cyan,green \"npm:dev:renderer\" \"npm:dev:electron\"",
    "dev:renderer": "vite --host 127.0.0.1",
    "dev:electron": "npm run build:main && wait-on tcp:5173 && electron .",
    "build": "npm run build:main && vite build",
    "e2e": "node e2e/check-task-editor.mjs",
    "build:main": "tsc -p tsconfig.main.json && node scripts/bundle-main.mjs",
    "bundle:daemon": "node scripts/bundle-daemon.mjs",
    "gen:app-config": "node scripts/gen-app-config.mjs",
    "package": "[ -f ../.env.production ] && { set -a; . ../.env.production; set +a; }; npm run build && npm run bundle:daemon && npm run gen:app-config && node scripts/package.mjs",
    "release": "node scripts/release.mjs",
    "typecheck": "tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.renderer.json --noEmit",
    "doctor": "react-doctor"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@convex-dev/auth": "^0.0.92",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@mdxeditor/editor": "^4.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.39.1",
    "electron-updater": "^6.8.3",
    "jsonc-parser": "^3.3.1",
    "lucide-react": "^1.17.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.10.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.0",
    "esbuild": "^0.27.0",
    "playwright-core": "^1.60.0",
    "react-doctor": "^0.2.16",
    "tailwindcss": "^4",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "wait-on": "^9.0.3"
  }
}
